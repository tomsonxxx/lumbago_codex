# ===================================================================
# Lumbago Music AI — przykładowy plik zmiennych środowiskowych
# Skopiuj do .env i uzupełnij własnymi kluczami
# ===================================================================

# --- Tryby diagnostyczne ---
LUMBAGO_SAFE_MODE=0
LUMBAGO_DISABLE_MULTIMEDIA=0
LUMBAGO_VERBOSE=0
LUMBAGO_RESET_DB=0

# --- Baza danych ---
DATABASE_URL=sqlite:///lumbago.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/lumbago

# --- AI: OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- AI: Anthropic Claude ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# --- AI: xAI Grok ---
GROK_API_KEY=xai-...
GROK_MODEL=grok-beta

# --- AI: DeepSeek ---
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# --- AI: Google Gemini ---
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# --- Acoustid (fingerprinting) ---
ACOUSTID_API_KEY=

# --- MusicBrainz ---
MUSICBRAINZ_APP=LumbagoMusic/1.0
MUSICBRAINZ_RATE_LIMIT=1.0

# --- Discogs ---
DISCOGS_USER_TOKEN=
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=

# --- Last.fm ---
LASTFM_API_KEY=
LASTFM_API_SECRET=
LASTFM_USERNAME=
LASTFM_PASSWORD_HASH=

# --- Spotify ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# --- Analiza audio ---
LIBROSA_CACHE_DIR=.cache/librosa
WAVEFORM_RESOLUTION=1000
LUFS_TARGET=-14.0
BPM_MIN=60
BPM_MAX=220

# --- Import ---
WATCH_DIRECTORIES=
IMPORT_BATCH_SIZE=50
IMPORT_THREADS=4

# --- Backup ---
BACKUP_DIR=
BACKUP_MAX_COUNT=10

# --- UI ---
DEFAULT_THEME=cyber_neon
LANGUAGE=pl
