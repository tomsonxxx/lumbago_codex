<Window
    x:Class="LumbagoWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LumbagoWinUI"
    Title="Lumbago Music AI">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource BgBrush}" RowDefinitions="Auto,*,Auto">

        <!-- ===== TOPBAR ===== -->
        <Grid Grid.Row="0" Height="56" Padding="16,0"
              Background="{StaticResource PanelBrush2}"
              BorderBrush="{StaticResource StrokeBrush}"
              BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <TextBlock Grid.Column="0"
                           Text="LUMBAGO"
                           Style="{StaticResource SectionText}"
                           Foreground="{StaticResource AccentCyanBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"/>

                <AutoSuggestBox Grid.Column="1"
                                x:Name="GlobalSearch"
                                PlaceholderText="Szukaj utworów, artystów, playlist..."
                                MaxWidth="480"
                                HorizontalAlignment="Stretch"
                                QuerySubmitted="GlobalSearch_QuerySubmitted"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="BtnSettings"
                            Content="⚙"
                            Style="{StaticResource GhostButton}"
                            Click="BtnSettings_Click"
                            ToolTipService.ToolTip="Ustawienia"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ===== NAWIGACJA + TREŚĆ ===== -->
        <NavigationView
            Grid.Row="1"
            x:Name="NavView"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            SelectionFollowsFocus="Enabled"
            OpenPaneLength="220"
            CompactPaneLength="52"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Start" Tag="Start">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Biblioteka" Tag="Library">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Import" Tag="Import">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B5;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator/>

                <NavigationViewItemHeader Content="NARZĘDZIA AI"/>

                <NavigationViewItem Content="Smart Tagger" Tag="SmartTagger">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE950;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Duplikaty" Tag="Duplicates">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71D;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Konwerter XML" Tag="Converter">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Ustawienia" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <!-- ===== PLAYER DOCK ===== -->
        <Border Grid.Row="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,1,0,0">
            <Grid RowDefinitions="*,Auto" Padding="16,8,16,4">

                <!-- Główny wiersz playera -->
                <Grid Grid.Row="0" ColumnDefinitions="240,*,200">

                    <!-- Okładka + info o tracku -->
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border Width="44" Height="44" CornerRadius="6"
                                Background="{StaticResource PanelBrush2}">
                            <TextBlock Text="♪" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource SubTextBrush}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center" MaxWidth="180">
                            <TextBlock x:Name="PlayerTitle"
                                       Text="Brak utworu"
                                       Style="{StaticResource SectionText}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="PlayerArtist"
                                       Text="—"
                                       Style="{StaticResource CaptionText}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Transport -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button x:Name="BtnPrev"
                                Content="⏮"
                                Style="{StaticResource GhostButton}"
                                Width="36"
                                Click="BtnPrev_Click"
                                ToolTipService.ToolTip="Poprzedni"/>
                        <Button x:Name="BtnPlayPause"
                                Content="⏵"
                                Style="{StaticResource PrimaryButton}"
                                Width="44"
                                Click="BtnPlayPause_Click"
                                ToolTipService.ToolTip="Odtwórz / Pauza"/>
                        <Button x:Name="BtnNext"
                                Content="⏭"
                                Style="{StaticResource GhostButton}"
                                Width="36"
                                Click="BtnNext_Click"
                                ToolTipService.ToolTip="Następny"/>
                    </StackPanel>

                    <!-- BPM / Key / Czas -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="PlayerPosition"
                                   Text="0:00"
                                   Style="{StaticResource CaptionText}"/>
                        <TextBlock Text="/"
                                   Style="{StaticResource CaptionText}"
                                   Foreground="{StaticResource SubTextBrush}"/>
                        <TextBlock x:Name="PlayerDuration"
                                   Text="0:00"
                                   Style="{StaticResource CaptionText}"/>
                        <TextBlock x:Name="PlayerBpm"
                                   Text="— BPM"
                                   Style="{StaticResource CaptionText}"/>
                        <TextBlock x:Name="PlayerKey"
                                   Text="—"
                                   Style="{StaticResource CaptionText}"
                                   Foreground="{StaticResource AccentCyanBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Pasek seek -->
                <Slider Grid.Row="1"
                        x:Name="PlayerSeek"
                        Minimum="0"
                        Maximum="1"
                        Value="0"
                        StepFrequency="0.001"
                        SmallChange="0.01"
                        HorizontalAlignment="Stretch"
                        Height="20"
                        Margin="0,2,0,0"
                        ThumbToolTipValueConverter="{x:Null}"
                        ManipulationStarted="PlayerSeek_ManipulationStarted"
                        ManipulationCompleted="PlayerSeek_ManipulationCompleted"
                        ValueChanged="PlayerSeek_ValueChanged"/>
            </Grid>
        </Border>

    </Grid>
</Window>
