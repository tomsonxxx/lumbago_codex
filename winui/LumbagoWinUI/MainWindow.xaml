<Window
    x:Class="LumbagoWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LumbagoWinUI"
    Title="Lumbago Music AI">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource BgBrush}" RowDefinitions="Auto,*,Auto">

        <!-- ===== TOPBAR ===== -->
        <Grid Grid.Row="0" Height="56" Padding="16,0"
              Background="{StaticResource PanelBrush2}"
              BorderBrush="{StaticResource StrokeBrush}"
              BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <TextBlock Grid.Column="0"
                           Text="LUMBAGO"
                           Style="{StaticResource SectionText}"
                           Foreground="{StaticResource AccentCyanBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,24,0"/>

                <AutoSuggestBox Grid.Column="1"
                                x:Name="GlobalSearch"
                                PlaceholderText="Szukaj utworów, artystów, playlist..."
                                MaxWidth="480"
                                HorizontalAlignment="Stretch"
                                QuerySubmitted="GlobalSearch_QuerySubmitted"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="BtnSettings"
                            Content="⚙"
                            Style="{StaticResource GhostButton}"
                            Click="BtnSettings_Click"
                            ToolTipService.ToolTip="Ustawienia"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ===== NAWIGACJA + TREŚĆ ===== -->
        <NavigationView
            Grid.Row="1"
            x:Name="NavView"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            SelectionFollowsFocus="Enabled"
            OpenPaneLength="220"
            CompactPaneLength="52"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Start" Tag="Start">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Biblioteka" Tag="Library">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Import" Tag="Import">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B5;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator/>

                <NavigationViewItemHeader Content="NARZĘDZIA AI"/>

                <NavigationViewItem Content="Duplikaty" Tag="Duplicates">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE71D;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Konwerter XML" Tag="Converter">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Ustawienia" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <!-- ===== PLAYER DOCK ===== -->
        <Border Grid.Row="2" Height="72"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <!-- Okładka + info -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="6"
                            Background="{StaticResource PanelBrush2}">
                        <TextBlock Text="♪" FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SubTextBrush}"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PlayerTitle"
                                   Text="Brak utworu"
                                   Style="{StaticResource SectionText}"/>
                        <TextBlock x:Name="PlayerArtist"
                                   Text="—"
                                   Style="{StaticResource CaptionText}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Transport -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="⏮" Style="{StaticResource GhostButton}" Width="36"/>
                    <Button Content="⏵" Style="{StaticResource PrimaryButton}" Width="44"/>
                    <Button Content="⏭" Style="{StaticResource GhostButton}" Width="36"/>
                </StackPanel>

                <!-- BPM / Key -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="PlayerBpm"
                               Text="— BPM"
                               Style="{StaticResource CaptionText}"/>
                    <TextBlock x:Name="PlayerKey"
                               Text="—"
                               Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource AccentCyanBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
