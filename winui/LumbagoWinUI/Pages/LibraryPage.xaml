<Page
    x:Class="LumbagoWinUI.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LumbagoWinUI.Models"
    Background="{StaticResource BgBrush}">

    <Grid RowDefinitions="Auto,*">

        <!-- ===== TOOLBAR ===== -->
        <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="*,Auto" ColumnSpacing="12"
              Background="{StaticResource PanelBrush2}"
              BorderBrush="{StaticResource StrokeBrush}"
              BorderThickness="0,0,0,1">

            <AutoSuggestBox Grid.Column="0"
                            x:Name="SearchBox"
                            PlaceholderText="Filtruj bibliotekę..."
                            TextChanged="SearchBox_TextChanged"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="Odśwież"
                        Style="{StaticResource GhostButton}"
                        Click="BtnRefresh_Click"/>
            </StackPanel>
        </Grid>

        <!-- ===== TREŚĆ ===== -->
        <Grid Grid.Row="1">

            <!-- Stan ładowania -->
            <StackPanel x:Name="LoadingPanel"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="16">
                <ProgressRing IsActive="True" Width="48" Height="48"
                              Foreground="{StaticResource AccentCyanBrush}"/>
                <TextBlock Text="Ładowanie biblioteki..." Style="{StaticResource CaptionText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Stan pusty -->
            <StackPanel x:Name="EmptyPanel"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="16" Visibility="Collapsed">
                <FontIcon Glyph="&#xE8F1;" FontSize="64"
                          Foreground="{StaticResource SubTextBrush}"
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Biblioteka jest pusta" Style="{StaticResource SubtitleText}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Przejdź do Import, aby dodać pliki audio"
                           Style="{StaticResource CaptionText}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Lista tracków -->
            <Grid x:Name="TrackListPanel" Visibility="Collapsed" RowDefinitions="Auto,*">

                <!-- Nagłówek kolumn -->
                <Border Grid.Row="0"
                        Background="{StaticResource PanelBrush2}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,8">
                    <Grid ColumnDefinitions="*,160,120,80,60,72">
                        <TextBlock Grid.Column="0" Text="TYTUŁ / ARTYSTA" Style="{StaticResource CaptionText}"/>
                        <TextBlock Grid.Column="1" Text="ALBUM" Style="{StaticResource CaptionText}"/>
                        <TextBlock Grid.Column="2" Text="GATUNEK" Style="{StaticResource CaptionText}"/>
                        <TextBlock Grid.Column="3" Text="BPM" Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="KEY" Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="CZAS" Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Lista -->
                <ListView Grid.Row="1"
                          x:Name="TrackList"
                          ItemsSource="{x:Bind FilteredTracks, Mode=OneWay}"
                          SelectionMode="Single"
                          SelectionChanged="TrackList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="16,6"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Track">
                            <Grid ColumnDefinitions="*,160,120,80,60,72" ColumnSpacing="8">

                                <!-- Tytuł + artysta -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind DisplayTitle}"
                                               Style="{StaticResource BodyText}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind DisplayArtist}"
                                               Style="{StaticResource CaptionText}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Album -->
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind DisplayAlbum}"
                                           Style="{StaticResource CaptionText}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Gatunek -->
                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind Genre}"
                                           Style="{StaticResource CaptionText}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- BPM -->
                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind DisplayBpm}"
                                           Style="{StaticResource CaptionText}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource AccentGreenBrush}"/>

                                <!-- Key -->
                                <TextBlock Grid.Column="4"
                                           Text="{x:Bind DisplayKey}"
                                           Style="{StaticResource CaptionText}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource AccentCyanBrush}"/>

                                <!-- Czas -->
                                <TextBlock Grid.Column="5"
                                           Text="{x:Bind DisplayDuration}"
                                           Style="{StaticResource CaptionText}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

        </Grid>

    </Grid>
</Page>
