<Page
    x:Class="LumbagoWinUI.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LumbagoWinUI.Models"
    Background="{StaticResource BgBrush}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ===== TOOLBAR ===== -->
        <Grid Grid.Row="0" Padding="16,10" ColumnDefinitions="*,Auto" ColumnSpacing="12"
              Background="{StaticResource PanelBrush2}"
              BorderBrush="{StaticResource StrokeBrush}"
              BorderThickness="0,0,0,1">

            <AutoSuggestBox Grid.Column="0"
                            x:Name="SearchBox"
                            PlaceholderText="Szukaj po tytule, artyście, albumie, gatunku..."
                            TextChanged="SearchBox_TextChanged"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <ToggleButton x:Name="BtnFilter"
                              Content="⚗ Filtry"
                              Style="{StaticResource GhostToggleButton}"
                              Checked="BtnFilter_Checked"
                              Unchecked="BtnFilter_Unchecked"/>
                <ToggleButton x:Name="BtnGridView"
                              Style="{StaticResource GhostToggleButton}"
                              ToolTipService.ToolTip="Przełącz widok"
                              Checked="BtnGridView_Checked"
                              Unchecked="BtnGridView_Unchecked">
                    <FontIcon Glyph="&#xE8A9;" FontSize="14"/>
                </ToggleButton>
                <Button Content="↺"
                        Style="{StaticResource GhostButton}"
                        Click="BtnRefresh_Click"
                        ToolTipService.ToolTip="Odśwież"/>
            </StackPanel>
        </Grid>

        <!-- ===== PANEL FILTRÓW (zwijany) ===== -->
        <Border Grid.Row="1"
                x:Name="FilterPanel"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal" Spacing="24">

                <StackPanel Spacing="4">
                    <TextBlock Text="GATUNEK" Style="{StaticResource CaptionText}"/>
                    <TextBox x:Name="FilterGenre"
                             PlaceholderText="np. Techno"
                             Width="140"
                             Style="{StaticResource NeonTextBox}"
                             TextChanged="FilterGenre_TextChanged"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="TONACJA" Style="{StaticResource CaptionText}"/>
                    <ComboBox x:Name="FilterKey"
                              PlaceholderText="Wszystkie"
                              Width="110"
                              SelectionChanged="FilterKey_SelectionChanged">
                        <ComboBoxItem Content="— wszystkie —" Tag=""/>
                        <ComboBoxItem Content="1A" Tag="1A"/>
                        <ComboBoxItem Content="2A" Tag="2A"/>
                        <ComboBoxItem Content="3A" Tag="3A"/>
                        <ComboBoxItem Content="4A" Tag="4A"/>
                        <ComboBoxItem Content="5A" Tag="5A"/>
                        <ComboBoxItem Content="6A" Tag="6A"/>
                        <ComboBoxItem Content="7A" Tag="7A"/>
                        <ComboBoxItem Content="8A" Tag="8A"/>
                        <ComboBoxItem Content="9A" Tag="9A"/>
                        <ComboBoxItem Content="10A" Tag="10A"/>
                        <ComboBoxItem Content="11A" Tag="11A"/>
                        <ComboBoxItem Content="12A" Tag="12A"/>
                        <ComboBoxItem Content="1B" Tag="1B"/>
                        <ComboBoxItem Content="2B" Tag="2B"/>
                        <ComboBoxItem Content="3B" Tag="3B"/>
                        <ComboBoxItem Content="4B" Tag="4B"/>
                        <ComboBoxItem Content="5B" Tag="5B"/>
                        <ComboBoxItem Content="6B" Tag="6B"/>
                        <ComboBoxItem Content="7B" Tag="7B"/>
                        <ComboBoxItem Content="8B" Tag="8B"/>
                        <ComboBoxItem Content="9B" Tag="9B"/>
                        <ComboBoxItem Content="10B" Tag="10B"/>
                        <ComboBoxItem Content="11B" Tag="11B"/>
                        <ComboBoxItem Content="12B" Tag="12B"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="BPM MIN" Style="{StaticResource CaptionText}"/>
                    <NumberBox x:Name="FilterBpmMin"
                               PlaceholderText="60"
                               Width="90"
                               Minimum="0" Maximum="300"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="FilterBpm_Changed"/>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="BPM MAX" Style="{StaticResource CaptionText}"/>
                    <NumberBox x:Name="FilterBpmMax"
                               PlaceholderText="200"
                               Width="90"
                               Minimum="0" Maximum="300"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="FilterBpm_Changed"/>
                </StackPanel>

                <Button Content="Wyczyść filtry"
                        Style="{StaticResource GhostButton}"
                        VerticalAlignment="Bottom"
                        Click="BtnClearFilters_Click"/>
            </StackPanel>
        </Border>

        <!-- ===== GŁÓWNA TREŚĆ (lista/siatka + panel szczegółów) ===== -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto">

            <!-- Lewa strona: widok tracków -->
            <Grid Grid.Column="0">

                <!-- Stan ładowania -->
                <StackPanel x:Name="LoadingPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="16">
                    <ProgressRing IsActive="True" Width="48" Height="48"
                                  Foreground="{StaticResource AccentCyanBrush}"/>
                    <TextBlock Text="Ładowanie biblioteki..." Style="{StaticResource CaptionText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Stan pusty -->
                <StackPanel x:Name="EmptyPanel"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="16" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE8F1;" FontSize="64"
                              Foreground="{StaticResource SubTextBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Biblioteka jest pusta" Style="{StaticResource SubtitleText}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Przejdź do Import, aby dodać pliki audio"
                               Style="{StaticResource CaptionText}"
                               HorizontalAlignment="Center"/>
                    <Button Content="Importuj pliki"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Center"
                            Click="BtnGoImport_Click"/>
                </StackPanel>

                <!-- WIDOK LISTY -->
                <Grid x:Name="TrackListPanel" Visibility="Collapsed" RowDefinitions="Auto,*">

                    <!-- Nagłówek kolumn -->
                    <Border Grid.Row="0"
                            Background="{StaticResource PanelBrush2}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,6">
                        <Grid ColumnDefinitions="*,150,110,72,56,64">
                            <TextBlock Grid.Column="0" Text="TYTUŁ / ARTYSTA"
                                       Style="{StaticResource CaptionText}"/>
                            <TextBlock Grid.Column="1" Text="ALBUM"
                                       Style="{StaticResource CaptionText}"/>
                            <TextBlock Grid.Column="2" Text="GATUNEK"
                                       Style="{StaticResource CaptionText}"/>
                            <TextBlock Grid.Column="3" Text="BPM"
                                       Style="{StaticResource CaptionText}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="KEY"
                                       Style="{StaticResource CaptionText}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="CZAS"
                                       Style="{StaticResource CaptionText}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ListView Grid.Row="1"
                              x:Name="TrackList"
                              ItemsSource="{x:Bind FilteredTracks, Mode=OneWay}"
                              SelectionMode="Single"
                              SelectionChanged="TrackList_SelectionChanged"
                              DoubleTapped="TrackList_DoubleTapped">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="16,5"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Track">
                                <Grid ColumnDefinitions="*,150,110,72,56,64" ColumnSpacing="8">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind DisplayTitle}"
                                                   Style="{StaticResource BodyText}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind DisplayArtist}"
                                                   Style="{StaticResource CaptionText}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind DisplayAlbum}"
                                               Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind Genre}"
                                               Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind DisplayBpm}"
                                               Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource AccentGreenBrush}"/>
                                    <TextBlock Grid.Column="4"
                                               Text="{x:Bind DisplayKey}"
                                               Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource AccentCyanBrush}"/>
                                    <TextBlock Grid.Column="5"
                                               Text="{x:Bind DisplayDuration}"
                                               Style="{StaticResource CaptionText}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- WIDOK SIATKI -->
                <GridView x:Name="TrackGrid"
                          ItemsSource="{x:Bind FilteredTracks, Mode=OneWay}"
                          SelectionMode="Single"
                          Padding="12"
                          SelectionChanged="TrackGrid_SelectionChanged"
                          Visibility="Collapsed">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:Track">
                            <Border Width="160" Height="200" Margin="6"
                                    Background="{StaticResource PanelBrush}"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource StrokeBrush}"
                                    BorderThickness="1">
                                <Grid RowDefinitions="*,Auto">
                                    <!-- Okładka placeholder -->
                                    <Border Grid.Row="0" CornerRadius="12,12,0,0"
                                            Background="{StaticResource PanelBrush2}">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Spacing="4">
                                            <FontIcon Glyph="&#xE8D6;" FontSize="40"
                                                      Foreground="{StaticResource SubTextBrush}"/>
                                            <TextBlock Text="{x:Bind DisplayBpm}"
                                                       Style="{StaticResource CaptionText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource AccentGreenBrush}"/>
                                            <TextBlock Text="{x:Bind DisplayKey}"
                                                       Style="{StaticResource CaptionText}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{StaticResource AccentCyanBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Metadane -->
                                    <StackPanel Grid.Row="1" Padding="10,8" Spacing="2">
                                        <TextBlock Text="{x:Bind DisplayTitle}"
                                                   Style="{StaticResource BodyText}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"/>
                                        <TextBlock Text="{x:Bind DisplayArtist}"
                                                   Style="{StaticResource CaptionText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

            </Grid>

            <!-- Prawa strona: panel szczegółów / edycji -->
            <Border Grid.Column="1"
                    x:Name="DetailPanel"
                    Width="320"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource StrokeBrush}"
                    BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">

                        <!-- Okładka placeholder -->
                        <Border Height="240" CornerRadius="12"
                                Background="{StaticResource PanelBrush2}"
                                Margin="0,0,0,4">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                                <FontIcon Glyph="&#xE8D6;" FontSize="64"
                                          Foreground="{StaticResource SubTextBrush}"/>
                                <TextBlock x:Name="DetailArtworkHint"
                                           Text="Brak okładki"
                                           Style="{StaticResource CaptionText}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Pola edycji -->
                        <TextBlock Text="TYTUŁ" Style="{StaticResource CaptionText}"/>
                        <TextBox x:Name="DetailTitle" Style="{StaticResource NeonTextBox}"/>

                        <TextBlock Text="ARTYSTA" Style="{StaticResource CaptionText}"/>
                        <TextBox x:Name="DetailArtist" Style="{StaticResource NeonTextBox}"/>

                        <TextBlock Text="ALBUM" Style="{StaticResource CaptionText}"/>
                        <TextBox x:Name="DetailAlbum" Style="{StaticResource NeonTextBox}"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="BPM" Style="{StaticResource CaptionText}"/>
                                <TextBox x:Name="DetailBpm" Style="{StaticResource NeonTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="TONACJA" Style="{StaticResource CaptionText}"/>
                                <TextBox x:Name="DetailKey" Style="{StaticResource NeonTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="GATUNEK" Style="{StaticResource CaptionText}"/>
                        <TextBox x:Name="DetailGenre" Style="{StaticResource NeonTextBox}"/>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="ROK" Style="{StaticResource CaptionText}"/>
                                <TextBox x:Name="DetailYear" Style="{StaticResource NeonTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="NR TRACKA" Style="{StaticResource CaptionText}"/>
                                <TextBox x:Name="DetailTrackNumber" Style="{StaticResource NeonTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="KOMENTARZ" Style="{StaticResource CaptionText}"/>
                        <TextBox x:Name="DetailComment"
                                 Style="{StaticResource NeonTextBox}"
                                 AcceptsReturn="True"
                                 Height="60"/>

                        <!-- Pola tylko do odczytu -->
                        <Border Style="{StaticResource NeonCardBorder}" Padding="12" Margin="0,4,0,0">
                            <StackPanel Spacing="6">
                                <TextBlock Text="INFORMACJE" Style="{StaticResource CaptionText}"
                                           Foreground="{StaticResource SubTextBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Czas:" Style="{StaticResource CaptionText}"/>
                                    <TextBlock x:Name="DetailDuration"
                                               Style="{StaticResource CaptionText}"
                                               Foreground="{StaticResource TextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Format:" Style="{StaticResource CaptionText}"/>
                                    <TextBlock x:Name="DetailFormat"
                                               Style="{StaticResource CaptionText}"
                                               Foreground="{StaticResource TextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Bitrate:" Style="{StaticResource CaptionText}"/>
                                    <TextBlock x:Name="DetailBitrate"
                                               Style="{StaticResource CaptionText}"
                                               Foreground="{StaticResource TextBrush}"/>
                                </StackPanel>
                                <TextBlock x:Name="DetailPath"
                                           Style="{StaticResource CaptionText}"
                                           Foreground="{StaticResource SubTextBrush}"
                                           TextWrapping="Wrap"
                                           IsTextSelectionEnabled="True"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Przyciski akcji -->
                        <TextBlock x:Name="DetailStatus"
                                   Style="{StaticResource CaptionText}"
                                   Visibility="Collapsed"/>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button x:Name="BtnDetailSave"
                                    Content="Zapisz"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnDetailSave_Click"/>
                            <Button Content="Resetuj"
                                    Style="{StaticResource GhostButton}"
                                    Click="BtnDetailReset_Click"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </Grid>
</Page>
