<Page
    x:Class="LumbagoWinUI.Pages.ConverterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBrush}">

    <ScrollViewer Padding="32,24">
        <StackPanel Spacing="24" MaxWidth="680">

            <!-- Nagłówek -->
            <StackPanel Spacing="4">
                <TextBlock Text="Konwerter XML" Style="{StaticResource TitleText}"/>
                <TextBlock Text="Konwertuj playlisty DJ między formatami Rekordbox i VirtualDJ"
                           Style="{StaticResource CaptionText}"/>
            </StackPanel>

            <!-- Sekcja wejściowa: Rekordbox -->
            <Border Style="{StaticResource NeonCardBorder}">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8A5;" FontSize="20"
                                  Foreground="{StaticResource AccentVioletBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="PLIK WEJŚCIOWY — REKORDBOX XML"
                                   Style="{StaticResource SectionText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBox x:Name="TxtInputPath"
                                 Grid.Column="0"
                                 PlaceholderText="Wybierz plik rekordbox.xml..."
                                 Style="{StaticResource NeonTextBox}"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="1"
                                Content="Wybierz plik"
                                Style="{StaticResource GhostButton}"
                                Click="BtnPickInput_Click"/>
                    </Grid>

                    <TextBlock x:Name="TxtTrackCount"
                               Style="{StaticResource CaptionText}"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Strzałka konwersji -->
            <TextBlock Text="↓  konwertuj do  ↓"
                       Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource AccentVioletBrush}"/>

            <!-- Sekcja wyjściowa: VirtualDJ -->
            <Border Style="{StaticResource NeonCardBorder}">
                <StackPanel Spacing="14">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE8A5;" FontSize="20"
                                  Foreground="{StaticResource AccentCyanBrush}"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="PLIK WYJŚCIOWY — VIRTUALDJ XML"
                                   Style="{StaticResource SectionText}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBox x:Name="TxtOutputPath"
                                 Grid.Column="0"
                                 PlaceholderText="Wybierz lokalizację zapisu..."
                                 Style="{StaticResource NeonTextBox}"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="1"
                                Content="Wybierz lokalizację"
                                Style="{StaticResource GhostButton}"
                                Click="BtnPickOutput_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Status i przycisk konwersji -->
            <TextBlock x:Name="ConvertStatus"
                       Style="{StaticResource CaptionText}"
                       Visibility="Collapsed"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <ProgressRing x:Name="ConvertProgress"
                              Width="24" Height="24"
                              Foreground="{StaticResource AccentVioletBrush}"
                              Visibility="Collapsed"/>
                <Button x:Name="BtnConvert"
                        Content="Konwertuj"
                        Style="{StaticResource PrimaryButton}"
                        IsEnabled="False"
                        Click="BtnConvert_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
