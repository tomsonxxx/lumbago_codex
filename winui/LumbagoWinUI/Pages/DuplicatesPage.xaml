<Page
    x:Class="LumbagoWinUI.Pages.DuplicatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBrush}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <FontIcon Glyph="&#xE71D;" FontSize="64"
                      Foreground="{StaticResource AccentWarningBrush}"
                      HorizontalAlignment="Center"/>
            <TextBlock Text="Duplikaty — w budowie" Style="{StaticResource SubtitleText}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ta strona zostanie zaimplementowana w Fazie 2"
                       Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
