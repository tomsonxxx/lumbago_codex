<Page
    x:Class="LumbagoWinUI.Pages.DuplicatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBrush}">

    <Grid RowDefinitions="Auto,*" Margin="32,24">

        <!-- Nagłówek + kontrolki analizy -->
        <Border Grid.Row="0" Style="{StaticResource NeonCardBorder}" Margin="0,0,0,16">
            <StackPanel Spacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Wyszukiwarka duplikatów" Style="{StaticResource TitleText}"/>
                    <TextBlock Text="Znajdź zduplikowane tracki w bibliotece i usuń zbędne kopie"
                               Style="{StaticResource CaptionText}"/>
                </StackPanel>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">

                    <!-- Tryb analizy -->
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="TRYB" Style="{StaticResource CaptionText}"/>
                        <ComboBox x:Name="ModeCombo" Width="200" SelectedIndex="2">
                            <ComboBoxItem Content="Hash (identyczne pliki)"  Tag="hash"/>
                            <ComboBoxItem Content="Odcisk (AcoustID)"        Tag="fingerprint"/>
                            <ComboBoxItem Content="Metadane (tytuł+artysta)" Tag="metadata"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Status -->
                    <TextBlock Grid.Column="1"
                               x:Name="StatusMsg"
                               Style="{StaticResource CaptionText}"
                               VerticalAlignment="Bottom"
                               Visibility="Collapsed"/>

                    <!-- Przycisk analizy -->
                    <Button Grid.Column="2"
                            x:Name="BtnAnalyze"
                            Content="Analizuj bibliotekę"
                            Style="{StaticResource PrimaryButton}"
                            VerticalAlignment="Bottom"
                            Click="BtnAnalyze_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing x:Name="AnalyzeProgress"
                                                  Width="16" Height="16"
                                                  Visibility="Collapsed"/>
                                    <TextBlock Text="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Wyniki: grupy duplikatów -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="GroupsPanel" Spacing="12">

                <!-- Stan pusty -->
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            Margin="0,80,0,0"
                            Spacing="16">
                    <FontIcon Glyph="&#xE71D;" FontSize="64"
                              Foreground="{StaticResource SubTextBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Brak duplikatów do wyświetlenia"
                               Style="{StaticResource SubtitleText}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Kliknij 'Analizuj bibliotekę', aby rozpocząć"
                               Style="{StaticResource CaptionText}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Grupy wypełniane dynamicznie przez kod C# -->

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
