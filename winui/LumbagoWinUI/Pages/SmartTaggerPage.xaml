<Page
    x:Class="LumbagoWinUI.Pages.SmartTaggerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LumbagoWinUI.Models"
    Background="{StaticResource BgBrush}">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Padding="24,20">

        <!-- ===== NAGŁÓWEK ===== -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="Smart AI Tagger" Style="{StaticResource SubtitleText}"/>
                <TextBlock x:Name="SubtitleLabel"
                           Text="Analizuje tagi muzyczne wszystkich tracków przy pomocy AI i proponuje uzupełnienia."
                           Style="{StaticResource CaptionText}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="BtnAcceptAll"
                        Content="✓ Zaakceptuj wszystkie"
                        Style="{StaticResource GhostButton}"
                        Click="BtnAcceptAll_Click"
                        Visibility="Collapsed"/>
                <Button x:Name="BtnRejectAll"
                        Content="✗ Odrzuć wszystkie"
                        Style="{StaticResource GhostButton}"
                        Click="BtnRejectAll_Click"
                        Visibility="Collapsed"/>
                <Button x:Name="BtnRunTagger"
                        Content="▶  Uruchom AI Tagger"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnRunTagger_Click"/>
            </StackPanel>
        </Grid>

        <!-- ===== PASEK POSTĘPU ===== -->
        <Border Grid.Row="1" Style="{StaticResource NeonCardBorder}"
                x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,16">
            <StackPanel Spacing="10">
                <Grid>
                    <TextBlock x:Name="ProgressText"
                               Text="Uruchamianie analizy..."
                               Style="{StaticResource BodyText}"/>
                    <TextBlock x:Name="ProgressCount"
                               Text=""
                               Style="{StaticResource CaptionText}"
                               HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar x:Name="ProgressBar"
                             IsIndeterminate="False"
                             Value="0"
                             Maximum="100"
                             Height="6"
                             Foreground="{StaticResource AccentCyanBrush}"/>
            </StackPanel>
        </Border>

        <!-- ===== PASEK STATUSU (po zakończeniu) ===== -->
        <Border Grid.Row="2" x:Name="StatusPanel" Visibility="Collapsed"
                CornerRadius="10" Padding="16,10" Margin="0,0,0,16">
            <TextBlock x:Name="StatusText" Style="{StaticResource BodyText}" TextWrapping="Wrap"/>
        </Border>

        <!-- ===== LISTA WYNIKÓW ===== -->
        <Border Grid.Row="3" Style="{StaticResource NeonCardBorder}"
                x:Name="ResultsPanel" Visibility="Collapsed" Padding="0">

            <!-- nagłówek tabeli -->
            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,140,140,64"
                      Padding="20,10"
                      Background="{StaticResource PanelBrush2}"
                      CornerRadius="16,16,0,0">
                    <TextBlock Text="TRACK / POLE" Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource AccentCyanBrush}"/>
                    <TextBlock Grid.Column="1" Text="STARA WARTOŚĆ" Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource AccentCyanBrush}"/>
                    <TextBlock Grid.Column="2" Text="NOWA WARTOŚĆ" Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource AccentCyanBrush}"/>
                    <TextBlock Grid.Column="3" Text="OK?" Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource AccentCyanBrush}"
                               HorizontalAlignment="Center"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListView x:Name="ResultsList"
                              ItemsSource="{x:Bind AnalysisItems}"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:TrackAnalysisViewModel">
                                <StackPanel>
                                    <!-- wiersz nagłówka tracka -->
                                    <Border Background="{StaticResource PanelBrush}"
                                            Padding="20,8"
                                            BorderBrush="{StaticResource StrokeBrush}"
                                            BorderThickness="0,1,0,0">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Text="{x:Bind TrackTitle}"
                                                       Style="{StaticResource SectionText}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind ProviderBadge}"
                                                       Style="{StaticResource CaptionText}"
                                                       Foreground="{StaticResource AccentVioletBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- decyzje per pole -->
                                    <ItemsControl ItemsSource="{x:Bind Decisions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:DecisionViewModel">
                                                <Grid ColumnDefinitions="*,140,140,64"
                                                      Padding="20,6"
                                                      BorderBrush="{StaticResource StrokeBrush}"
                                                      BorderThickness="0,0,0,1">
                                                    <TextBlock Text="{x:Bind FieldDisplay}"
                                                               Style="{StaticResource CaptionText}"
                                                               VerticalAlignment="Center"
                                                               Margin="16,0,0,0"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{x:Bind OldDisplay}"
                                                               Style="{StaticResource CaptionText}"
                                                               Foreground="{StaticResource SubTextBrush}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{x:Bind NewDisplay}"
                                                               Style="{StaticResource CaptionText}"
                                                               Foreground="{StaticResource AccentCyanBrush}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <CheckBox Grid.Column="3"
                                                              IsChecked="{x:Bind Accepted, Mode=TwoWay}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ===== STOPKA ===== -->
        <Grid Grid.Row="4" x:Name="FooterPanel" Visibility="Collapsed" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="FooterStatus"
                       Style="{StaticResource CaptionText}"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="✓  Zastosuj zaakceptowane zmiany"
                    Style="{StaticResource PrimaryButton}"
                    Click="BtnApply_Click"/>
        </Grid>

    </Grid>
</Page>
