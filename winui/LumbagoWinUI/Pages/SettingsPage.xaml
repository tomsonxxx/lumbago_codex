<Page
    x:Class="LumbagoWinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBrush}">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="32" MaxWidth="640">

            <TextBlock Text="Ustawienia" Style="{StaticResource TitleText}"/>

            <!-- Sekcja: Klucze API AI -->
            <Border Style="{StaticResource NeonCardBorder}">
                <StackPanel Spacing="16">
                    <TextBlock Text="KLUCZE API — AI" Style="{StaticResource SectionText}"
                               Foreground="{StaticResource AccentCyanBrush}"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="OpenAI" Style="{StaticResource CaptionText}"/>
                        <PasswordBox x:Name="TxtOpenAi" PlaceholderText="sk-..." Height="40"
                                     Background="{StaticResource PanelBrush2}"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource StrokeBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Grok (xAI)" Style="{StaticResource CaptionText}"/>
                        <PasswordBox x:Name="TxtGrok" PlaceholderText="xai-..." Height="40"
                                     Background="{StaticResource PanelBrush2}"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource StrokeBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Gemini (Google AI)" Style="{StaticResource CaptionText}"/>
                        <PasswordBox x:Name="TxtGemini" PlaceholderText="AIza..." Height="40"
                                     Background="{StaticResource PanelBrush2}"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource StrokeBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="DeepSeek" Style="{StaticResource CaptionText}"/>
                        <PasswordBox x:Name="TxtDeepSeek" PlaceholderText="sk-..." Height="40"
                                     Background="{StaticResource PanelBrush2}"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource StrokeBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sekcja: Klucze API Metadane -->
            <Border Style="{StaticResource NeonCardBorder}">
                <StackPanel Spacing="16">
                    <TextBlock Text="KLUCZE API — METADANE" Style="{StaticResource SectionText}"
                               Foreground="{StaticResource AccentVioletBrush}"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="AcoustID" Style="{StaticResource CaptionText}"/>
                        <TextBox x:Name="TxtAcoustId" PlaceholderText="Twój klucz AcoustID" Height="40"
                                 Style="{StaticResource NeonTextBox}"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Discogs (token)" Style="{StaticResource CaptionText}"/>
                        <PasswordBox x:Name="TxtDiscogs" PlaceholderText="Twój token Discogs" Height="40"
                                     Background="{StaticResource PanelBrush2}"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderBrush="{StaticResource StrokeBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Przyciski akcji -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="BtnSave"
                        Content="Zapisz ustawienia"
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnSave_Click"/>
                <Button Content="Anuluj"
                        Style="{StaticResource GhostButton}"
                        Click="BtnCancel_Click"/>
            </StackPanel>

            <!-- Status zapisu -->
            <TextBlock x:Name="StatusMsg"
                       Text=""
                       Style="{StaticResource CaptionText}"
                       Foreground="{StaticResource AccentGreenBrush}"
                       Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>
</Page>
