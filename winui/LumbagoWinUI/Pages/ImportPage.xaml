<Page
    x:Class="LumbagoWinUI.Pages.ImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:LumbagoWinUI.Models"
    Background="{StaticResource BgBrush}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="32,24">

        <!-- Nagłówek -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="Import plików audio" Style="{StaticResource TitleText}"/>
            <TextBlock Text="Zaimportuj pliki MP3, FLAC, WAV i inne do biblioteki"
                       Style="{StaticResource CaptionText}"/>
        </StackPanel>

        <!-- Środek: konfiguracja + podgląd -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*">

            <!-- Panel konfiguracji -->
            <Border Grid.Row="0" Style="{StaticResource NeonCardBorder}" Margin="0,0,0,16">
                <StackPanel Spacing="16">

                    <TextBlock Text="FOLDER ŹRÓDŁOWY" Style="{StaticResource CaptionText}"
                               Foreground="{StaticResource AccentCyanBrush}"/>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <TextBox x:Name="TxtFolder"
                                 Grid.Column="0"
                                 PlaceholderText="Ścieżka do folderu z muzyką..."
                                 Style="{StaticResource NeonTextBox}"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="1"
                                Content="Wybierz folder"
                                Style="{StaticResource GhostButton}"
                                Click="BtnBrowse_Click"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox x:Name="ChkRecursive"
                                  Content="Uwzględnij podfoldery"
                                  IsChecked="True"
                                  Foreground="{StaticResource TextBrush}"/>
                        <Button x:Name="BtnScan"
                                Content="Skanuj folder"
                                Style="{StaticResource PrimaryButton}"
                                IsEnabled="False"
                                Click="BtnScan_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="ScanStatus"
                               Style="{StaticResource CaptionText}"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Pasek wyboru podglądu -->
            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8"
                  x:Name="PreviewToolbar" Visibility="Collapsed">
                <TextBlock Grid.Column="0"
                           x:Name="TxtPreviewCount"
                           Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Content="Zaznacz wszystkie"
                            Style="{StaticResource GhostButton}"
                            Click="BtnSelectAll_Click"/>
                    <Button Content="Odznacz"
                            Style="{StaticResource GhostButton}"
                            Click="BtnDeselectAll_Click"/>
                </StackPanel>
            </Grid>

            <!-- Lista podglądu -->
            <ListView Grid.Row="2"
                      x:Name="PreviewList"
                      SelectionMode="Multiple"
                      Visibility="Collapsed">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="12,5"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Track">
                        <Grid ColumnDefinitions="*,100,60,64" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind DisplayTitle}"
                                           Style="{StaticResource BodyText}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{x:Bind Path}"
                                           Style="{StaticResource CaptionText}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind DisplayArtist}"
                                       Style="{StaticResource CaptionText}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind Format}"
                                       Style="{StaticResource CaptionText}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentCyanBrush}"/>
                            <TextBlock Grid.Column="3"
                                       Text="{x:Bind DisplayDuration}"
                                       Style="{StaticResource CaptionText}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

        </Grid>

        <!-- Dolny pasek akcji -->
        <Border Grid.Row="2"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,16,0,0"
                Margin="0,8,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           x:Name="ImportStatus"
                           Style="{StaticResource CaptionText}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <ProgressRing x:Name="ImportProgress"
                                  Width="24" Height="24"
                                  Foreground="{StaticResource AccentCyanBrush}"
                                  Visibility="Collapsed"/>
                    <Button x:Name="BtnImport"
                            Content="Importuj zaznaczone"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="False"
                            Click="BtnImport_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Page>
