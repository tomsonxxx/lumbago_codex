<Page
    x:Class="LumbagoWinUI.Pages.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgBrush}">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="32">

            <!-- Nagłówek -->
            <StackPanel Spacing="4">
                <TextBlock Text="Lumbago Music AI" Style="{StaticResource TitleText}"/>
                <TextBlock Text="Zarządzaj biblioteką muzyczną" Style="{StaticResource CaptionText}"/>
            </StackPanel>

            <!-- Siatka kart startowych -->
            <TextBlock Text="AKCJE" Style="{StaticResource CaptionText}" Margin="0,0,0,-8"/>
            <Grid x:Name="ActionGrid" ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Biblioteka -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource NeonCardBorder}"
                        x:Name="CardLibrary" PointerPressed="Card_PointerPressed" Tag="Library">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE8F1;" FontSize="32" Foreground="{StaticResource AccentCyanBrush}"/>
                        <TextBlock Text="Biblioteka" Style="{StaticResource SectionText}"/>
                        <TextBlock Text="Przeglądaj i edytuj swoje tracki" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Import -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource NeonCardBorder}"
                        x:Name="CardImport" PointerPressed="Card_PointerPressed" Tag="Import">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE8B5;" FontSize="32" Foreground="{StaticResource AccentGreenBrush}"/>
                        <TextBlock Text="Import" Style="{StaticResource SectionText}"/>
                        <TextBlock Text="Zaimportuj pliki audio z folderu" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Duplikaty -->
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource NeonCardBorder}"
                        x:Name="CardDuplicates" PointerPressed="Card_PointerPressed" Tag="Duplicates">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE71D;" FontSize="32" Foreground="{StaticResource AccentWarningBrush}"/>
                        <TextBlock Text="Duplikaty" Style="{StaticResource SectionText}"/>
                        <TextBlock Text="Znajdź i usuń zduplikowane tracki" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Konwerter XML -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource NeonCardBorder}"
                        x:Name="CardConverter" PointerPressed="Card_PointerPressed" Tag="Converter">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE8A5;" FontSize="32" Foreground="{StaticResource AccentVioletBrush}"/>
                        <TextBlock Text="Konwerter XML" Style="{StaticResource SectionText}"/>
                        <TextBlock Text="Rekordbox ↔ VirtualDJ" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Ustawienia -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource NeonCardBorder}"
                        x:Name="CardSettings" PointerPressed="Card_PointerPressed" Tag="Settings">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE713;" FontSize="32" Foreground="{StaticResource SubTextBrush}"/>
                        <TextBlock Text="Ustawienia" Style="{StaticResource SectionText}"/>
                        <TextBlock Text="Klucze API i konfiguracja" Style="{StaticResource CaptionText}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
