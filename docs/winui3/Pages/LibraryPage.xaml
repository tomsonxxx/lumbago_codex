<Page
    x:Class="LumbagoWin.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" ColumnDefinitions="*,280" RowDefinitions="Auto,*">
        <TextBlock Text="Biblioteka" Style="{StaticResource TitleText}"/>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
            <AutoSuggestBox PlaceholderText="Szukaj..." />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Gatunek" Style="{StaticResource GhostButton}"/>
                <Button Content="Artysta" Style="{StaticResource GhostButton}"/>
                <Button Content="Album" Style="{StaticResource GhostButton}"/>
                <Button Content="Sortuj" Style="{StaticResource GhostButton}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Column="0" Margin="0,48,16,0" Style="{StaticResource NeonCardBorder}">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Lista utworów" Style="{StaticResource SectionText}"/>
                <ListView Grid.Row="1">
                    <ListView.Header>
                        <Grid ColumnDefinitions="2*,2*,2*,Auto,Auto">
                            <TextBlock Text="Tytuł" />
                            <TextBlock Text="Artysta" Grid.Column="1"/>
                            <TextBlock Text="Album" Grid.Column="2"/>
                            <TextBlock Text="Czas" Grid.Column="3"/>
                            <TextBlock Text="Dodano" Grid.Column="4"/>
                        </Grid>
                    </ListView.Header>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="1" Column="1" Margin="0,48,0,0" Style="{StaticResource NeonCardBorder}">
            <StackPanel Spacing="12">
                <TextBlock Text="Filtry" Style="{StaticResource SectionText}"/>
                <TextBlock Text="Nastrój" Style="{StaticResource CaptionText}"/>
                <Slider Minimum="0" Maximum="100"/>
                <TextBlock Text="Tempo" Style="{StaticResource CaptionText}"/>
                <Slider Minimum="60" Maximum="200"/>
                <TextBlock Text="Energia" Style="{StaticResource CaptionText}"/>
                <Slider Minimum="0" Maximum="1"/>

                <TextBlock Text="Narzędzia AI" Style="{StaticResource SectionText}" Margin="0,12,0,0"/>
                <Button Content="Rekomendacje" Style="{StaticResource GhostButton}"/>
                <Button Content="Utwórz playlistę" Style="{StaticResource GhostButton}"/>
                <Button Content="Asystent tekstów" Style="{StaticResource GhostButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
