<Page
    x:Class="LumbagoWin.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowDefinitions="Auto,*">
        <TextBlock Text="Ustawienia" Style="{StaticResource TitleText}"/>

        <Grid Grid.Row="1" Style="{StaticResource NeonCard}">
            <StackPanel Spacing="12">
                <TextBlock Text="Klucze API" Style="{StaticResource SectionText}"/>
                <TextBox Header="AcoustID"/>
                <TextBox Header="MusicBrainz"/>
                <TextBox Header="Discogs"/>
                <TextBox Header="Grok"/>
                <TextBox Header="DeepSeek"/>
                <TextBox Header="OpenAI"/>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Zapisz" Style="{StaticResource PrimaryButton}"/>
                    <Button Content="Anuluj" Style="{StaticResource GhostButton}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
