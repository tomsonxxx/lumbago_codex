<Page
    x:Class="LumbagoWin.Pages.ConverterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowDefinitions="Auto,*">
        <TextBlock Text="Konwerter XML" Style="{StaticResource TitleText}"/>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="16">
            <Border Style="{StaticResource NeonCardBorder}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Wejście: Rekordbox" Style="{StaticResource SectionText}"/>
                    <Button Content="Wybierz plik XML" Style="{StaticResource GhostButton}"/>
                    <TextBlock Text="Podgląd: 0 utworów" Style="{StaticResource CaptionText}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource NeonCardBorder}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Wyjście: VirtualDJ" Style="{StaticResource SectionText}"/>
                    <Button Content="Zapisz XML" Style="{StaticResource PrimaryButton}"/>
                    <TextBlock Text="Tryb: dry-run / produkcyjny" Style="{StaticResource CaptionText}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
