<ContentDialog
    x:Class="LumbagoWin.Pages.TagCompareDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Porównanie tagów"
    PrimaryButtonText="Zastosuj"
    SecondaryButtonText="Anuluj">

    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,*" ColumnSpacing="16">
        <TextBlock Text="Stare tagi" Style="{StaticResource SectionText}"/>
        <TextBlock Text="Nowe tagi" Grid.Column="1" Style="{StaticResource SectionText}"/>

        <ListView Grid.Row="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Title" Width="120"/>
                        <TextBox Width="220"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ListView Grid.Row="1" Grid.Column="1">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Title" Width="120"/>
                        <TextBox Width="220"/>
                        <Button Content="↔" Style="{StaticResource GhostButton}"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentDialog>
