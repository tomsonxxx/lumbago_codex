<Page
    x:Class="LumbagoWin.Pages.DuplicatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowDefinitions="Auto,*">
        <TextBlock Text="Duplikaty" Style="{StaticResource TitleText}"/>

        <Grid Grid.Row="1" Style="{StaticResource NeonCard}">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Skanuj" Style="{StaticResource PrimaryButton}"/>
                    <Button Content="Eksport raportu" Style="{StaticResource GhostButton}"/>
                </StackPanel>
                <ListView>
                    <ListView.Header>
                        <Grid ColumnDefinitions="Auto,2*,2*,*,*">
                            <TextBlock Text="Grupa"/>
                            <TextBlock Text="Tytuł" Grid.Column="1"/>
                            <TextBlock Text="Artysta" Grid.Column="2"/>
                            <TextBlock Text="Rozmiar" Grid.Column="3"/>
                            <TextBlock Text="Akcje" Grid.Column="4"/>
                        </Grid>
                    </ListView.Header>
                </ListView>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
