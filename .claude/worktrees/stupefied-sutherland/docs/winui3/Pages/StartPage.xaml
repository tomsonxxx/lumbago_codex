<Page
    x:Class="LumbagoWin.Pages.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowDefinitions="Auto,Auto,*">
        <TextBlock Text="Start" Style="{StaticResource TitleText}"/>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,16,0,16" ColumnSpacing="16" RowSpacing="16">
            <Grid Style="{StaticResource NeonCard}">
                <StackPanel Spacing="8">
                    <FontIcon Glyph="&#xE189;" Foreground="{StaticResource AccentCyanBrush}" FontSize="28"/>
                    <TextBlock Text="Nowe wydania" Style="{StaticResource SectionText}"/>
                </StackPanel>
            </Grid>
            <Grid Style="{StaticResource NeonCard}">
                <StackPanel Spacing="8">
                    <FontIcon Glyph="&#xE734;" Foreground="{StaticResource AccentPinkBrush}" FontSize="28"/>
                    <TextBlock Text="Top listy" Style="{StaticResource SectionText}"/>
                </StackPanel>
            </Grid>
            <Grid Style="{StaticResource NeonCard}">
                <StackPanel Spacing="8">
                    <FontIcon Glyph="&#xE995;" Foreground="{StaticResource AccentGreenBrush}" FontSize="28"/>
                    <TextBlock Text="Mixy dla Ciebie" Style="{StaticResource SectionText}"/>
                </StackPanel>
            </Grid>
            <Grid Style="{StaticResource NeonCard}">
                <StackPanel Spacing="8">
                    <FontIcon Glyph="&#xE8A5;" Foreground="{StaticResource AccentCyanBrush}" FontSize="28"/>
                    <TextBlock Text="Odkrywaj" Style="{StaticResource SectionText}"/>
                </StackPanel>
            </Grid>
            <Grid Style="{StaticResource NeonCard}">
                <StackPanel Spacing="8">
                    <FontIcon Glyph="&#xE710;" Foreground="{StaticResource AccentPinkBrush}" FontSize="28"/>
                    <TextBlock Text="Utwórz playlistę" Style="{StaticResource SectionText}"/>
                </StackPanel>
            </Grid>
            <Grid Style="{StaticResource NeonCard}">
                <StackPanel Spacing="8">
                    <FontIcon Glyph="&#xE7C3;" Foreground="{StaticResource AccentGreenBrush}" FontSize="28"/>
                    <TextBlock Text="Wydarzenia live" Style="{StaticResource SectionText}"/>
                </StackPanel>
            </Grid>
        </UniformGrid>

        <Grid Grid.Row="2" Height="140" Style="{StaticResource NeonCard}">
            <TextBlock Text="Podgląd wizualizacji / wykresu energii" Style="{StaticResource CaptionText}"/>
        </Grid>
    </Grid>
</Page>
