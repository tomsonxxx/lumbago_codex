<Page
    x:Class="LumbagoWin.Pages.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" ColumnDefinitions="*,280" RowDefinitions="Auto,*">
        <TextBlock Text="Biblioteka" Style="{StaticResource TitleText}"/>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
            <AutoSuggestBox PlaceholderText="Szukaj..." />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Genre" Style="{StaticResource GhostButton}"/>
                <Button Content="Artist" Style="{StaticResource GhostButton}"/>
                <Button Content="Album" Style="{StaticResource GhostButton}"/>
                <Button Content="Sort" Style="{StaticResource GhostButton}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Column="0" Margin="0,48,16,0" Style="{StaticResource NeonCard}">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Lista utworów" Style="{StaticResource SectionText}"/>
                <ListView Grid.Row="1">
                    <ListView.Header>
                        <Grid ColumnDefinitions="2*,2*,2*,Auto,Auto">
                            <TextBlock Text="Title" />
                            <TextBlock Text="Artist" Grid.Column="1"/>
                            <TextBlock Text="Album" Grid.Column="2"/>
                            <TextBlock Text="Duration" Grid.Column="3"/>
                            <TextBlock Text="Added" Grid.Column="4"/>
                        </Grid>
                    </ListView.Header>
                </ListView>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Column="1" Margin="0,48,0,0" Style="{StaticResource NeonCard}">
            <StackPanel Spacing="12">
                <TextBlock Text="Filtry" Style="{StaticResource SectionText}"/>
                <TextBlock Text="Mood" Style="{StaticResource CaptionText}"/>
                <Slider Minimum="0" Maximum="100"/>
                <TextBlock Text="Tempo" Style="{StaticResource CaptionText}"/>
                <Slider Minimum="60" Maximum="200"/>
                <TextBlock Text="Energy" Style="{StaticResource CaptionText}"/>
                <Slider Minimum="0" Maximum="1"/>

                <TextBlock Text="AI Tools" Style="{StaticResource SectionText}" Margin="0,12,0,0"/>
                <Button Content="Song Recommendations" Style="{StaticResource GhostButton}"/>
                <Button Content="Create Playlist" Style="{StaticResource GhostButton}"/>
                <Button Content="Lyrics Assistant" Style="{StaticResource GhostButton}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
