<Window
    x:Class="LumbagoWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LumbagoWin"
    Background="{ThemeResource SystemControlAcrylicWindowBrush}">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt"/>
    </Window.SystemBackdrop>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Górny pasek poleceń -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Icon="GlobalNavigationButton" Label="Menu"/>
            <AutoSuggestBox
                Width="360"
                PlaceholderText="Szukaj utworów, artystów, playlist..."
                Margin="12,0,12,0"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Setting" Label="Ustawienia"/>
        </CommandBar>

        <!-- Nawigacja + treść -->
        <NavigationView
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            SelectionFollowsFocus="Enabled">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Start" Icon="Home"/>
                <NavigationViewItem Content="Biblioteka" Icon="Library"/>
                <NavigationViewItem Content="Ulubione" Icon="Favorite"/>
                <NavigationViewItem Content="Import" Icon="Import"/>
            </NavigationView.MenuItems>

            <NavigationView.MenuItemsSource>
                <!-- dynamiczne playlisty -->
            </NavigationView.MenuItemsSource>

            <NavigationView.PaneFooter>
                <StackPanel Spacing="8">
                    <TextBlock Text="NARZĘDZIA AI" Style="{StaticResource CaptionText}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Tagger" Style="{StaticResource GhostButton}"/>
                        <Button Content="Duplikaty" Style="{StaticResource GhostButton}"/>
                        <Button Content="Konwerter" Style="{StaticResource GhostButton}"/>
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Globalny odtwarzacz -->
        <Grid Grid.Row="2" Padding="12" Background="{StaticResource PanelBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Image Width="48" Height="48" Margin="0,0,12,0"/>
                <StackPanel>
                    <TextBlock Text="Track Title — Artist" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="Album • 3:45 • 125 BPM" Foreground="{StaticResource SubTextBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button Content="⏮" Style="{StaticResource GhostButton}"/>
                    <Button Content="⏵" Style="{StaticResource PrimaryButton}"/>
                    <Button Content="⏭" Style="{StaticResource GhostButton}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
